# =============================================================================
# 智能旅行助手 - 环境变量配置示例
# 
# 使用方式：
# 1. 复制本文件为 .env:  cp .env.example .env
# 2. 将下方占位符替换为你的真实 API 密钥
# 3. 确保安装了 python-dotenv: pip install python-dotenv
# 4. 运行程序时会自动加载此文件中的配置
# =============================================================================

# -------------------------
# OpenAI 兼容 LLM 配置
# -------------------------

# API 密钥（从服务商处获取）
# 示例: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=YOUR_API_KEY_HERE

# API 基础 URL（取决于你使用的服务商）
# OpenAI 官方: https://api.openai.com/v1
# Azure OpenAI: https://YOUR_RESOURCE.openai.azure.com/
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
# Ollama 本地: http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型 ID（取决于服务商提供的模型）
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# 阿里云: qwen-max, qwen-plus, qwen-turbo
# Ollama: llama3, qwen2.5:14b 等
OPENAI_MODEL_ID=gpt-4o

# -------------------------
# Tavily 搜索 API 配置
# -------------------------

# Tavily API 密钥（用于景点搜索）
# 注册地址: https://tavily.com/
# 免费额度: 1000 次调用/月
TAVILY_API_KEY=YOUR_TAVILY_API_KEY_HERE
